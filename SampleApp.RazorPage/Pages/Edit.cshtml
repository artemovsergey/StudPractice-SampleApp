@page "/Edit/{id}"
@model SampleApp.RazorPage.Pages.EditModel

@{
    ViewData["Title"] = "Обновление";
}

<div flashes></div>

<h1>@ViewData["Title"]</h1>

<div class="row">
    <div class="col-md-6 col-md-offset-3">
        <form method="post" class="form-signin" role="form">
            <input type="hidden" asp-for="Input.Id" class="form-control" placeholder="Имя" required autofocus>
            <input type="text" asp-for="Input.Name" class="form-control" placeholder="Имя" required autofocus>
            <input type="email" asp-for="Input.Email" class="form-control" placeholder="Почта" required autofocus>
            <input type="password" asp-for="Input.Password" class="form-control" placeholder="Пароль" required autofocus>
            <input type="password" asp-for="Input.PasswordConfirmation" class="form-control" placeholder="Повторите пароль" required>
            <button class="btn btn-lg btn-primary btn-block" type="submit">
                Обновить пользователя
            </button>
        </form>
    </div>
</div>



