@page "/Edit/{id}"
@model SampleApp.RazorPage.Pages.EditModel

@{
    ViewData["Title"] = "Обновление";
}

<div flashes></div>

<h1>Обновление</h1>

<div class="row">
    <div class="col-md-6 col-md-offset-3">
        <form method="post" class="form-signin" role="form">
            <input type="text" name="Name" class="form-control" placeholder="Имя"
                   required autofocus>
            <input type="email" name="Email" class="form-control" placeholder="Почта"
                   required autofocus>
            <input type="password" name="Password" class="form-control"
                   placeholder="Пароль" required autofocus>
            <input type="password" name="PasswordConfirmation" class="form-control"
                   placeholder="Повторите пароль" required>
            <button class="btn btn-lg btn-primary btn-block" type="submit"
                    name="submit">
                Обновить пользователя
            </button>
        </form>
    </div>
</div>



@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
