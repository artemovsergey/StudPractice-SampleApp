@page "/Profile/{id}";
@model SampleApp.RazorPage.Pages.ProfileModel

<div>


    <div class="row">
        <aside class="col-md-4">
            <section class="user_info">
                <h1>
                    <h4> @Model.User.Name </h4>
                </h1>
            </section>
        </aside>
    </div>


    <hr />
    <dl class="dl-horizontal">
        <dt>
            @Html.DisplayNameFor(model => model.User.Name)
        </dt>
        <dd>
            @Html.DisplayFor(model => model.User.Name)
        </dd>
        <dt>
            @Html.DisplayNameFor(model => model.User.Email)
        </dt>
        <dd>
            @Html.DisplayFor(model => model.User.Email)
        </dd>
        <dt>
            @Html.DisplayNameFor(model => model.User.Password)
        </dt>
        <dd>
            @Html.DisplayFor(model => model.User.Password)
        </dd>
        <dt>
            @Html.DisplayNameFor(model => model.User.PasswordConfirmation)
        </dt>
        <dd>
            @Html.DisplayFor(model => model.User.PasswordConfirmation)
        </dd>
    </dl>
</div>
<div>
    <a asp-page="./Edit" asp-route-id="@Model.User.Id">Edit</a> |
    <a asp-page="./Index">Back to List</a>
</div>


@if (Model.IsLogin())
{
    <div class="row">
        <aside class="col-md-4">
            <section class="micropost_form">
                <form action="index.php" method="POST" class="form-signin" role="form">
                    <textarea rows="4" cols="50" type="text" name="textarea" required autofocus></textarea>
                    <button class="btn btn-lg btn-primary btn-block" type="submit" name="submit">Post</button>
                </form>
            </section>
        </aside>
    </div>


    <div class="col-md-8">
        <h3>
            Cообщения @Model.User.Microposts.Count()
        </h3>
        <ol class="microposts">

            @foreach (var post in Model.User.Microposts)
            {
                <p>
                    <b>@post.User.Name: </b> @post.Content
                </p>
            }

        </ol>
    </div>
}




